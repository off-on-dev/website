---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import {
  BRAND_NAME,
  COMMUNITY_URL,
  CONTACT_EMAIL,
  LINKEDIN_URL,
  BLUESKY_URL,
  X_URL,
  BRAND_SECONDARY_LINE_PARTS,
} from "@/lib/site";

const base = import.meta.env.BASE_URL;

const BRAND_SECONDARY_LINE = BRAND_SECONDARY_LINE_PARTS.join(" ");

// Community Leaders sidebar data (mirrors src/data/community-leaders.json).
// Refreshed hourly in the React app; embedded here as a build-time snapshot.
