---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import AdventureIcon from "@/components/AdventureIcon.astro";
import ContributorBadge from "@/components/ContributorBadge.astro";
import DifficultyBadge from "@/components/DifficultyBadge.astro";
import LivePill from "@/components/LivePill.astro";
import TagChips from "@/components/TagChips.astro";
import InlineProse from "@/components/InlineProse.astro";
import RewardsCard from "@/components/RewardsCard.astro";
import PersonNameLink from "@/components/PersonNameLink.astro";
import { BRAND_NAME } from "@/lib/site";
import { stripLinks } from "@/lib/markdown";
import { isDeadlinePast } from "@/lib/utils";
import { getLeaderboard } from "@/lib/community-data";

export async function getStaticPaths() {
  const adventures = await getCollection("adventures");
  return adventures.map((a) => ({ params: { id: a.id }, props: { adventure: a.data } }));
}

const { adventure } = Astro.props;
const base = import.meta.env.BASE_URL;

const deadlinePast = isDeadlinePast(adventure.rewards?.deadline);
const isLive = !!adventure.rewards?.deadline && !deadlinePast;
const upcoming = adventure.upcomingLevels ?? [];
const totalTiles = adventure.levels.length + upcoming.length;
const gridCols = totalTiles === 2 ? "sm:grid-cols-2" : "sm:grid-cols-2 lg:grid-cols-3";
const leaderboard = getLeaderboard(adventure.slug);
const topRows = leaderboard?.rows?.slice(0, 5) ?? [];
---

<Layout
  title={`${adventure.title} - ${BRAND_NAME} Adventures`}
  description={adventure.metaDescription}
  path={`/adventures/${adventure.slug}/`}
  ogType="article"
>
  <main id="main-content" tabindex="-1" class="px-6 pb-24 pt-12 md:px-16">
    <div class="mx-auto max-w-6xl">
      <Breadcrumb items={[{ label: "Adventures", href: "/adventures/" }, { label: adventure.title }]} />

      <div class="mb-10">
        <div class="mb-4 inline-flex items-center gap-3">
          <h1 class="text-3xl font-bold text-foreground md:text-4xl">{adventure.title}</h1>
          <AdventureIcon icon={adventure.icon} size={28} class="shrink-0 text-primary" />
        </div>
        <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          {adventure.contributor && (
            <ContributorBadge
              name={adventure.contributor.name}
              url={adventure.contributor.url}
              label="Adventure Builder"
            />
          )}
          <span class="font-mono text-xs uppercase tracking-widest text-faint">{adventure.month}</span>
        </div>
        <div class="mb-5 flex flex-wrap items-center gap-1.5">
          {isLive && <LivePill />}
          <TagChips tags={adventure.tags} />
        </div>
        <InlineProse html={adventure.story} class="max-w-3xl leading-relaxed text-dim" />
      </div>

      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-10">
        <div class="space-y-8">
          {adventure.overview && adventure.overview.length > 0 && (
            <section aria-labelledby="overview-heading">
              <h2 id="overview-heading" class="mb-4 text-lg font-semibold text-foreground">Overview</h2>
              <ul role="list" class="space-y-2.5">
                {adventure.overview.map((para) => (
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true" />
                    <p class="text-sm leading-relaxed text-dim">{para}</p>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section aria-labelledby="challenges-heading">
            <h2 id="challenges-heading" class="mb-5 text-lg font-semibold text-foreground">Challenges</h2>
            <div class={`grid gap-5 ${gridCols}`}>
              {adventure.levels.map((level) => {
                const descHtml = level.intro?.[0] ?? level.backstory?.[0];
                return (
                  <a
                    href={`${base}adventures/${adventure.slug}/levels/${level.id}/`}
                    aria-label={`Start the ${level.difficulty} level: ${level.name}`}
                    class="group card-glow relative flex flex-col rounded-xl border border-border bg-[hsl(var(--surface))] p-6 focus-ring"
                  >
                    <div class="mb-3 flex flex-wrap items-center gap-2">
                      <DifficultyBadge difficulty={level.difficulty} showDot />
                      {level.estimatedTime && (
                        <span class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-1 font-mono text-xs text-dim">
                          <Icon name="lucide:clock" width={11} height={11} aria-hidden="true" />
                          {level.estimatedTime}
                        </span>
                      )}
                    </div>
                    <h3 class="mb-3 text-lg font-semibold text-foreground transition-colors group-hover:text-primary">
                      {level.name}
                    </h3>
                    {descHtml && (
                      <p class="mb-4 line-clamp-4 flex-1 text-xs leading-relaxed text-dim md-inline" set:html={stripLinks(descHtml)} />
                    )}
                    <span
                      class="mt-auto inline-flex items-center gap-1 text-xs font-medium text-primary underline decoration-2 underline-offset-2"
                      aria-hidden="true"
                    >
                      Start Challenge
                      <Icon name="lucide:arrow-right" width={12} height={12} aria-hidden="true" />
                    </span>
                  </a>
                );
              })}
              {upcoming.map((u) => (
                <div class="relative flex flex-col rounded-xl border border-dashed border-border bg-[hsl(var(--surface))] p-6">
                  <div class="mb-3"><DifficultyBadge difficulty={u.difficulty} showDot /></div>
                  <h3 class="mb-3 text-lg font-semibold text-foreground">{u.name}</h3>
                  <span class="mt-auto inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-dim">
                    Coming Soon
                  </span>
                </div>
              ))}
            </div>
          </section>

          {adventure.rewards && !deadlinePast && <RewardsCard rewards={adventure.rewards} deadlinePast={false} />}

          {adventure.backstory && adventure.backstory.length > 0 && (
            <section aria-labelledby="story-heading">
              <h2 id="story-heading" class="mb-4 text-lg font-semibold text-foreground">The Story</h2>
              <div class="space-y-3">
                {adventure.backstory.map((para) => (
                  <InlineProse html={para} class="text-sm leading-relaxed text-dim" />
                ))}
              </div>
            </section>
          )}

          {adventure.rewards && deadlinePast && <RewardsCard rewards={adventure.rewards} deadlinePast={true} />}
        </div>

        <aside aria-label="Adventure resources" class="mt-10 space-y-6 lg:mt-0 lg:sticky lg:top-8 lg:self-start">
          {topRows.length > 0 && (
            <div class="rounded-xl border border-border bg-[hsl(var(--surface))] px-5 py-4">
              <p class="mb-3 font-mono text-xs uppercase tracking-widest text-faint">Leaderboard</p>
              <ol class="space-y-1.5">
                {topRows.map((row) => (
                  <li class="flex items-center justify-between text-sm text-dim">
                    <span><span class="text-faint">#{row.rank}</span> {row.username}</span>
                    <span class="text-faint">{row.points} pts</span>
                  </li>
                ))}
              </ol>
            </div>
          )}
          {adventure.contributor && (
            <div class="rounded-xl border border-border bg-[hsl(var(--surface))] px-5 py-4">
              <p class="mb-2 font-mono text-xs uppercase tracking-widest text-faint">Adventure by</p>
              <PersonNameLink name={adventure.contributor.name} url={adventure.contributor.url} />
              {adventure.contributor.aboutHtml && (
                <InlineProse html={adventure.contributor.aboutHtml} class="mt-2 text-sm leading-relaxed text-dim" />
              )}
            </div>
          )}
        </aside>
      </div>
    </div>
  </main>
</Layout>
