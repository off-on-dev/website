  {
    id: "most-replies",
    title: "Most Replies",
    users: [
      { username: "KatharinaSick", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/KatharinaSick/40/9_2.png", count: 39 },
      { username: "theharithsa", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/theharithsa/40/297_2.png", count: 16 },
      { username: "iw4p", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/iw4p/40/345_2.png", count: 11 },
      { username: "enri-kapaj", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/enri-kapaj/40/165_2.png", count: 10 },
      { username: "RoelofW", avatarUrl: "https://avatars.discourse-cdn.com/v4/letter/r/b5a626/40.png", count: 10 },
    ],
  },
  {
    id: "most-supportive",
    title: "Most Supportive",
    users: [
      { username: "KatharinaSick", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/KatharinaSick/40/9_2.png", count: 104 },
      { username: "SinduriGuntupalli", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/SinduriGuntupalli/40/194_2.png", count: 44 },
      { username: "DavidHirsch", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/DavidHirsch/40/8_2.png", count: 44 },
      { username: "theharithsa", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/theharithsa/40/297_2.png", count: 38 },
      { username: "AgataWlodarczyk", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/AgataWlodarczyk/40/51_2.png", count: 20 },
    ],
  },
];

const SECTION_ICONS: Record<string, string> = {
  "top-contributors": "lucide:trophy",
  "top-challenge-solvers": "lucide:target",
  "challenge-rockstars": "lucide:star",
  "challenge-grand-builders": "lucide:building-2",
  "challenge-builders": "lucide:wrench",
  "most-liked": "lucide:heart",
  "most-replies": "lucide:message-circle",
  "most-supportive": "lucide:hand-heart",
};
---

<Layout
  title={`About ${BRAND_NAME} - Building the contributors and maintainers of tomorrow`}
  description={`${BRAND_NAME} is the home for open source enthusiasts. Learn about our mission, who we're for, and the values that make this community different.`}
  path="/about/"
>
  <main id="main-content" tabindex="-1">
    {/* Hero */}
    <section
      aria-labelledby="about-hero-heading"
      class="bg-primary pt-32 pb-20 px-6 md:px-16 overflow-hidden min-h-[560px] flex flex-col justify-center bg-[length:8rem] md:bg-[length:12rem]"
      style={`background-image: url(${base}nyx_peek.webp); background-position: 75% bottom; background-repeat: no-repeat;`}
    >
      <div class="mx-auto max-w-6xl w-full">
        <div class="max-w-2xl">
          <span class="font-sans text-sm font-medium uppercase tracking-widest text-background/90 block mb-4">
            About
          </span>
          <h1 id="about-hero-heading" class="text-4xl md:text-5xl font-bold leading-tight tracking-tight text-primary-foreground mb-5">
            The Home for Open Source Enthusiasts
          </h1>
          <p class="font-sans text-base leading-relaxed text-background/90 max-w-2xl mb-8">
            Our mission, vision, who we're for, and the values that shape everything we build.
          </p>
          <a href={`mailto:${CONTACT_EMAIL}`} class="btn-inverse">
            <span class="inline-flex items-center gap-2"><Icon name="lucide:mail" width={14} height={14} aria-hidden="true" /> Contact Us</span>
          </a>
        </div>
      </div>
    </section>

    {/* Main content + Community Leaders sidebar (SidebarLayout with aside) */}
    <div class="px-6 md:px-16 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12">
          <div>
            {/* AboutSection */}
            <div id="approach" class="pb-16">
              <div>
                <div class="mb-3">
                  <span class="section-label font-sans text-sm font-medium uppercase tracking-widest text-primary">our foundation</span>
                </div>

                <div class="mb-8">
                  <h2 id="mission" class="text-2xl font-bold text-foreground">Our Mission</h2>
                  <div class="mt-4 flex flex-col gap-4 max-w-3xl">
                    <p class="text-lg text-foreground leading-relaxed">
                      {BRAND_NAME} exists to sustain the people behind open source and create the maintainers of tomorrow.
                    </p>
                    <p class="text-dim leading-relaxed">
                      We are a vendor-neutral, community-driven space built around one goal: supporting open source contributors and maintainers at every stage of their journey, from the first pull request to long-term stewardship.
                    </p>
                    <p class="text-dim leading-relaxed">
                      Most platforms, foundations, and content formats today are designed with enterprises, legal teams, or marketing goals in mind. Far fewer are built for the individuals who actually keep open source alive.
                    </p>
                    <p class="text-dim leading-relaxed">
                      As the ecosystem navigates new realities around regulation, digital sovereignty, and AI, {BRAND_NAME} gives the community a place to learn, share, mentor, and grow, from curious users to confident contributors, and from contributors to sustainable maintainers.
                    </p>
                  </div>
                </div>

                <div class="mb-8">
                  <h2 id="vision" class="text-2xl font-bold text-foreground">Our Vision</h2>
                  <div class="mt-4 flex flex-col gap-4 max-w-3xl">
                    <p class="text-dim leading-relaxed">
                      A future where open source is not only widely used, but actively sustained by a new generation of contributors and maintainers who are trained, supported, and connected, regardless of which company, country, or project they come from.
                    </p>
                    <p class="text-dim leading-relaxed">
                      We believe a real community has to be open. Open in its tooling, open in its governance, and open in how knowledge is preserved and passed on. {BRAND_NAME} is our attempt to put that belief into practice.
                    </p>
                  </div>
                </div>

                <div class="mb-8">
                  <h2 id="audience" class="text-2xl font-bold text-foreground">Who It's For</h2>
                  <div class="mt-4 max-w-3xl">
                    <ul role="list" class="flex flex-col gap-2">
                      {AUDIENCE_ITEMS.map((item) => (
                        <li class="flex items-start gap-2.5 text-sm text-dim">
                          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <div>
                  <h2 id="values" class="text-2xl font-bold text-foreground">What We Stand For</h2>
                  <div class="mt-4 max-w-3xl">
                    <ul role="list" class="flex flex-col gap-2">
                      {VALUE_ITEMS.map((item) => (
                        <li class="flex items-start gap-2.5 text-sm text-dim">
                          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                          <span>
                            <strong class="font-semibold text-foreground">{item.lead}</strong> {item.desc}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            {/* BrandStory */}
            <section id="story" aria-labelledby="story-heading" class="pb-16">
              <div>
                <div class="mb-3">
                  <span class="section-label font-sans text-sm font-medium uppercase tracking-widest text-primary">our story</span>
                </div>
                <h2 id="story-heading" class="text-2xl font-bold text-foreground">The Story Behind the Firefly</h2>
                <div class="mt-4 flex flex-col gap-4 max-w-3xl">
                  <p class="text-dim leading-relaxed">
                    When we rebranded, we wanted the name and the mascot to feel true to this community. We talked through a lot of ideas and kept coming back to the same question: what mascot could reflect a space built on curiosity, contribution, and learning by doing?
                  </p>
                  <p class="text-dim leading-relaxed">
                    At one point, someone said firefly, and it clicked. That is how Nyx came to life.
                  </p>
                  <p class="text-dim leading-relaxed">
                    Nyx is more than a mascot. The firefly reflects what {BRAND_NAME} is about: people showing up for each other, sharing what they know, and building something brighter together. Each person brings their own spark, but together, we glow brighter.
                  </p>
                  <p class="text-dim leading-relaxed">
                    That spark matters more than ever. AI can write code, but when it takes over all the work, how do people discover their passion or the creativity needed to design the best solutions? When curiosity fades, growth stops.
                  </p>
                  <p class="text-dim leading-relaxed">
                    Understanding how things work still matters. When we combine our thinking, that is where the real magic happens. The power of community is not just about being part of something. It is an engine that fuels human connection, curiosity, and genuine love for a topic. AI cannot replicate that experience.
                  </p>
                </div>
              </div>
            </section>

            {/* BoardSection */}
            <section id="board" aria-labelledby="board-heading" class="pb-16">
              <div>
                <div class="mb-3">
                  <span class="section-label font-sans text-sm font-medium uppercase tracking-widest text-primary">the people</span>
                </div>
                <h2 id="board-heading" class="text-2xl font-bold text-foreground">Board</h2>
                <p class="mt-4 max-w-3xl text-muted-foreground leading-relaxed">
                  The board guides the long-term direction of {BRAND_NAME}, stewarding its values, governance, and community priorities.
                </p>
                <div class="mt-8 grid gap-4 sm:grid-cols-2">
                  {BOARD_MEMBERS.map((member) => (
                    <div class="card-glow rounded-xl border border-border bg-[hsl(var(--surface))] p-6">
                      {member.image ? (
                        <img
                          src={`${base}${member.image}`}
                          alt={member.name}
                          width={AVATAR_SIZE}
                          height={AVATAR_SIZE}
                          loading="lazy"
                          decoding="async"
                          class="h-20 w-20 rounded-full object-cover"
                        />
                      ) : (
                        <div
                          aria-hidden="true"
                          class="flex h-20 w-20 items-center justify-center rounded-full border border-border bg-muted"
                        >
                          <Icon name="lucide:user" width={28} height={28} class="text-muted-foreground" />
                        </div>
                      )}
                      <div class="mt-4">
                        {member.url ? (
                          <a
                            href={member.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-describedby="new-tab-hint"
                            class="docs-ext-link text-base font-semibold"
                          >
                            {member.name}
                            <Icon name="lucide:external-link" width={12} height={12} aria-hidden="true" />
                          </a>
                        ) : (
                          <span class="text-base font-semibold text-foreground">{member.name}</span>
                        )}
                        <p class="mt-1.5 text-sm text-muted-foreground leading-relaxed">{member.about}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </section>
          </div>

          {/* Community Leaders sidebar (lg+ only, sticky) */}
          <div class="hidden lg:block">
            <div class="sticky top-24">
              <div class="rounded-xl border border-border bg-[hsl(var(--surface))] p-5">
                <h3 class="font-sans text-base font-semibold text-foreground mb-5">Community Leaders</h3>
                <div class="space-y-5">
                  {LEADER_SECTIONS.map((section) => (
                    <div class="pb-5 border-b border-border last:border-b-0 last:pb-0">
                      <div>
                        <h4 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
                          <span class="text-primary">
                            <Icon name={SECTION_ICONS[section.id]} width={14} height={14} aria-hidden="true" />
                          </span>
                          {section.title}
                        </h4>
                        <ol class="space-y-2.5" aria-label={section.title}>
                          {section.users.map((user, i) => (
                            <li class="flex items-center gap-3">
                              <span class="font-mono text-xs text-faint w-4 shrink-0 text-right" aria-hidden="true">{i + 1}</span>
                              <img
                                src={user.avatarUrl}
                                alt=""
                                aria-hidden="true"
                                width={28}
                                height={28}
                                loading="lazy"
                                decoding="async"
                                class="h-7 w-7 rounded-full shrink-0 object-cover"
                              />
                              <span class="text-sm font-medium text-foreground min-w-0 flex-1">
                                <span class="truncate">{user.username}</span>
                              </span>
                              <span class="text-xs font-mono text-dim tabular-nums shrink-0" aria-label={`${user.count} contributions`}>{user.count}</span>
                            </li>
                          ))}
                        </ol>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* ChallengeBuildersSection (SidebarLayout with no aside, full width) */}
    {ADVENTURE_CONTRIBUTORS.length > 0 && (
      <section id="challenge-builders" aria-labelledby="challenge-builders-heading" class="px-6 md:px-16 pb-16">
        <div class="mx-auto max-w-6xl">
          <div>
            <h2 id="challenge-builders-heading" class="text-2xl font-bold text-foreground">Challenge Builders</h2>
            <p class="mt-4 max-w-3xl text-muted-foreground leading-relaxed">
              Adventures don't build themselves. A heartfelt thank you to everyone who has put in the time and care to create them.
            </p>
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
              {ADVENTURE_CONTRIBUTORS.map((contributor) => (
                <div class="card-glow rounded-xl border border-border bg-[hsl(var(--surface))] p-6">
                  {contributor.url ? (
                    <a
                      href={contributor.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-describedby="new-tab-hint"
                      class="docs-ext-link text-base font-semibold"
                    >
                      {contributor.name}
                      <Icon name="lucide:external-link" width={12} height={12} aria-hidden="true" />
                    </a>
                  ) : (
                    <span class="text-base font-semibold text-foreground">{contributor.name}</span>
                  )}
                  {contributor.aboutHtml && (
                    <p class="mt-1.5 text-sm text-muted-foreground leading-relaxed md-inline" set:html={contributor.aboutHtml} />
                  )}
                  <p class="mt-6 mb-3 text-xs font-medium text-muted-foreground uppercase tracking-wider">adventures created</p>
                  <ul role="list" class="space-y-3">
                    {contributor.adventures.map(({ id, title }) => (
                      <li class="flex items-center gap-2 text-xs">
                        <span class="h-1 w-1 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                        <a href={`${base}adventures/${id}/`} class="docs-ext-link">
                          {title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {/* BottomCTA */}
    <section aria-labelledby="bottom-cta-heading" class="bg-primary py-16 px-6 md:px-16 relative overflow-hidden">
      <div class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1fr_1fr_auto] gap-12 lg:gap-16 items-center">
        {/* Left - headline */}
        <div>
          <h2 id="bottom-cta-heading" class="text-4xl md:text-5xl font-bold leading-tight tracking-tight text-primary-foreground">
            <span class="block">Start Curious.</span>
            <span class="block">Break Things.</span>
            <span class="block">Learn Together.</span>
            <span class="block">Glow Brighter.</span>
          </h2>
        </div>

        {/* Right - copy + buttons */}
        <div class="flex flex-col gap-4">
          <p class="font-sans text-base leading-relaxed text-background/90">
            <strong class="font-medium text-primary-foreground">
              You bring your questions, your fixes, your ideas.
            </strong>{" "}
            We bring the challenges, the tooling, and the practitioners who care about the same problems you do.
          </p>
          <p class="font-sans text-base leading-relaxed text-background/90">
            Every spark starts with one person. Like Nyx, our firefly, together we brighten the whole open source ecosystem.
          </p>
          <p class="font-sans text-base font-medium text-background/90">
            That's {BRAND_NAME}. {BRAND_SECONDARY_LINE}
          </p>
          <div class="flex gap-3 flex-wrap mt-2">
            <a
              href={COMMUNITY_URL}
              target="_blank"
              rel="noopener noreferrer"
              aria-describedby="new-tab-hint"
              class="btn-inverse"
            >
              Join the Community <Icon name="lucide:external-link" width={14} height={14} aria-hidden="true" />
            </a>
            <a
              href="https://github.com/off-on-dev/open-source-challenges"
              target="_blank"
              rel="noopener noreferrer"
              aria-describedby="new-tab-hint"
              class="btn-ghost-inverse"
            >
              View Challenges on GitHub <Icon name="lucide:external-link" width={14} height={14} aria-hidden="true" />
            </a>
          </div>
        </div>

        {/* Nyx mascot - third column, visible on lg+ only */}
        <img
          src={`${base}nyx.webp`}
          alt=""
          aria-hidden="true"
          width={240}
          height={240}
          loading="lazy"
          decoding="async"
          class="hidden lg:block w-[240px] h-[240px] self-start"
        />
      </div>
    </section>
  </main>
</Layout>
