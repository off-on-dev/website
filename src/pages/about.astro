      { username: "SinduriGuntupalli", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/SinduriGuntupalli/40/194_2.png", count: 16 },
      { username: "adrianamvillela", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/adrianamvillela/40/46_2.png", count: 14 },
      { username: "DavidHirsch", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/DavidHirsch/40/8_2.png", count: 14 },
      { username: "theharithsa", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/theharithsa/40/297_2.png", count: 4 },
    ],
  },
  {
    id: "challenge-grand-builders",
    title: "Challenge Grand Builders",
    users: [
      { username: "KatharinaSick", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/KatharinaSick/40/9_2.png", count: 14 },
    ],
  },
  {
    id: "top-challenge-solvers",
    title: "Top Challenge Solvers",
    users: [
      { username: "iw4p", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/iw4p/40/345_2.png", count: 9 },
      { username: "theharithsa", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/theharithsa/40/297_2.png", count: 9 },
      { username: "gsigmund", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/gsigmund/40/99_2.png", count: 8 },
      { username: "enri-kapaj", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/enri-kapaj/40/165_2.png", count: 6 },
      { username: "justinrand", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/justinrand/40/140_2.png", count: 6 },
      { username: "alvin", avatarUrl: "https://avatars.discourse-cdn.com/v4/letter/a/b5a626/40.png", count: 6 },
    ],
  },
  {
    id: "challenge-builders",
    title: "Challenge Builders",
    users: [
      { username: "simon.schrottner", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/simon.schrottner/40/311_2.png", count: 3 },
    ],
  },
  {
    id: "most-liked",
    title: "Most Liked",
    users: [
      { username: "KatharinaSick", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/KatharinaSick/40/9_2.png", count: 67 },
      { username: "SinduriGuntupalli", avatarUrl: "https://community.offon.dev/user_avatar/community.offon.dev/SinduriGuntupalli/40/194_2.png", count: 31 },
