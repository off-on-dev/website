---
import {
  BRAND_NAME,
  BRAND_SHORT_DESCRIPTION,
  COMMUNITY_URL,
  CODE_OF_CONDUCT_URL,
  CONTACT_EMAIL,
  LINKEDIN_URL,
  BLUESKY_URL,
  X_URL,
  CURRENT_YEAR,
} from "@/lib/site";

const base = import.meta.env.BASE_URL;
const explore = [
  { href: "challenges/", label: "Challenges" },
  { href: "contribute/", label: "Contribute" },
  { href: "handbook/", label: "Handbook" },
  { href: "about/", label: "About" },
  { href: "brand/", label: "Brand" },
];
const social = [
  { href: LINKEDIN_URL, label: "LinkedIn" },
  { href: BLUESKY_URL, label: "Bluesky" },
  { href: X_URL, label: "X / Twitter" },
];
---

<footer class="mt-16 border-t border-border">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <p class="font-heading text-lg font-bold text-foreground">{BRAND_NAME}</p>
        <p class="mt-2 max-w-xs text-sm text-dim">{BRAND_SHORT_DESCRIPTION}</p>
      </div>

      <nav aria-label="Explore">
        <p class="mb-3 font-sans text-xs font-normal uppercase tracking-widest text-faint">explore</p>
        <ul class="space-y-2">
          {explore.map((l) => (
            <li><a class="inline-flex items-center min-h-[48px] text-sm text-dim hover:text-foreground focus-ring rounded-sm" href={base + l.href}>{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Community">
        <p class="mb-3 font-sans text-xs font-normal uppercase tracking-widest text-faint">community</p>
        <ul class="space-y-2">
          <li><a class="docs-ext-link text-sm" href={COMMUNITY_URL} target="_blank" rel="noopener noreferrer" aria-describedby="new-tab-hint">Community Hub</a></li>
          <li><a class="docs-ext-link text-sm" href={CODE_OF_CONDUCT_URL} target="_blank" rel="noopener noreferrer" aria-describedby="new-tab-hint">Code of Conduct</a></li>
          <li><a class="inline-flex items-center min-h-[48px] text-sm text-dim hover:text-foreground focus-ring rounded-sm" href={`${base}privacy/`}>Privacy Policy</a></li>
          <li><a class="inline-flex items-center min-h-[48px] text-sm text-dim hover:text-foreground focus-ring rounded-sm" href={`${base}accessibility/`}>Accessibility</a></li>
          <li><a class="inline-flex items-center min-h-[48px] text-sm text-dim hover:text-foreground focus-ring rounded-sm" href={`mailto:${CONTACT_EMAIL}`}>Contact</a></li>
        </ul>
      </nav>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-border pt-6">
      <p class="text-xs text-faint">© {CURRENT_YEAR} {BRAND_NAME}. Licensed under MIT and CC BY 4.0.</p>
      <ul class="flex gap-4">
        {social.map((s) => (
          <li>
            <a class="inline-flex items-center min-h-[48px] text-sm text-dim hover:text-foreground focus-ring rounded-sm" href={s.href} target="_blank" rel="noopener noreferrer" aria-describedby="new-tab-hint">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
