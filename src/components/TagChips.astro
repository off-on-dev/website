---
import { tagToSlug } from "@/lib/challenges";

interface Props {
  tags: string[];
}
const { tags } = Astro.props;
const base = import.meta.env.BASE_URL;
---

{
  tags.map((tag) => (
    <a
      href={`${base}challenges/${tagToSlug(tag)}/`}
      class="tag-chip-link rounded-sm border border-border px-2.5 py-1 text-xs text-faint transition-colors hover:border-foreground/40 hover:text-foreground dark:hover:border-primary dark:hover:text-primary"
    >
      {tag}
    </a>
  ))
}
