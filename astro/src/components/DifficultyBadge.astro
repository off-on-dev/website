---
import { difficultyStyle } from "@/lib/difficulty";

interface Props {
  difficulty: string;
  showDot?: boolean;
}
const { difficulty, showDot = false } = Astro.props;
---

<span
  class="inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 font-mono text-xs uppercase tracking-wider transition-colors"
  style={difficultyStyle(difficulty)}
  data-difficulty={difficulty}
>
  {showDot && <span class="h-2 w-2 rounded-full bg-current" aria-hidden="true"></span>}
  {difficulty}
</span>
