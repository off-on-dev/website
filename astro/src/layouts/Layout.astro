---
import { ClientRouter } from "astro:transitions";
import "@/styles/index.css";

// Phase 1 shell. Replaces src/root.tsx. Full per-page SEO (<SEO> component,
// OG/Twitter/canonical/per-page JSON-LD) lands in Phase 3; this accepts the
// minimum for a valid document.
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL;
// PR-preview deployments (BASE_URL=/pr-preview/pr-N/) must not be indexed.
// Narrow check so it never fires in production (BASE_URL="/").
const isPreview = base.startsWith("/pr-preview/");

// --- Ported verbatim from src/root.tsx (do not paraphrase these strings) ---
const themeScript = `(function(){try{var t=localStorage.getItem("theme");if(t==="light"){document.documentElement.classList.remove("dark");document.documentElement.classList.add("light");}}catch(e){}})();`;

const gtagBootstrap = `window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied'});`;

// With <ClientRouter />, re-assert the theme class after each swap, before paint,
// so the theme does not flash on client navigation (research-confirmed gotcha).
const themeAfterSwap = `document.addEventListener("astro:after-swap",function(){try{var t=localStorage.getItem("theme");var c=document.documentElement.classList;if(t==="light"){c.remove("dark");c.add("light");}else{c.remove("light");c.add("dark");}}catch(e){}});`;

const webSiteJsonLd = `{"@context":"https://schema.org","@type":"WebSite","name":"OffOn","url":"https://offon.dev","description":"A vendor-neutral community for open source enthusiasts. Learn through hands-on challenges, share what you know, and connect with people who love open source."}`;

const orgJsonLd = `{"@context":"https://schema.org","@type":"Organization","name":"OffOn","url":"https://offon.dev","logo":"https://offon.dev/brand/offon-logo-dark-color.png","sameAs":["https://www.linkedin.com/company/offondev","https://community.offon.dev","https://github.com/off-on-dev/open-source-challenges"]}`;

const fontPreloads = [
  "fonts/inter-latin-400-normal.woff2",
  "fonts/inter-latin-500-normal.woff2",
  "fonts/inter-latin-600-normal.woff2",
  "fonts/syne-latin-700-normal.woff2",
];
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="author" content="offon.dev" />

    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon.png`} type="image/png" />
    <link rel="shortcut icon" href={`${base}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />

    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5f5ff" media="(prefers-color-scheme: light)" />

    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com; base-uri 'self'; form-action 'self';"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    {isPreview && <meta name="robots" content="noindex" />}

    <link rel="sitemap" type="application/xml" href={`${base}sitemap.xml`} />
    <link rel="api-catalog" href={`${base}.well-known/api-catalog`} />

    {fontPreloads.map((f) => (
      <link rel="preload" href={`${base}${f}`} as="font" type="font/woff2" crossorigin="anonymous" />
    ))}

    {/* Theme set before paint to prevent flash of wrong theme */}
    <script is:inline set:html={themeScript} />
    <script is:inline set:html={themeAfterSwap} />
    {/* Consent Mode v2 default-denied bootstrap. gtag.js loads later, only on Accept (Phase 4). */}
    <script is:inline set:html={gtagBootstrap} />

    <script type="application/ld+json" is:inline set:html={webSiteJsonLd} />
    <script type="application/ld+json" is:inline set:html={orgJsonLd} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
