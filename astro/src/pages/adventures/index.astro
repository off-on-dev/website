---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import AdventureCard from "@/components/AdventureCard.astro";
import { BRAND_NAME } from "@/lib/site";

const MONTHS = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
const monthKey = (m: string): number => {
  const [mon, year] = m.split(" ");
  return Number(year) * 12 + Math.max(0, MONTHS.indexOf(mon));
};

const now = new Date();
const isLive = (a: { rewards?: { deadline?: string }; levels: { deadline?: string }[] }): boolean =>
  !!(a.rewards?.deadline && new Date(a.rewards.deadline) > now) ||
  a.levels.some((l) => l.deadline && new Date(l.deadline) > now);

const adventures = (await getCollection("adventures"))
  .map((a) => a.data)
  .sort((x, y) => monthKey(y.month) - monthKey(x.month));
---

<Layout
  title={`Adventures - ${BRAND_NAME}`}
  description="Hands-on open source adventures. Learn by fixing real systems across GitOps, observability, progressive delivery, and more."
  path="/adventures/"
>
  <main id="main-content" tabindex="-1" class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="font-heading text-3xl font-bold text-foreground md:text-4xl">Adventures</h1>
    <p class="mt-3 text-dim">Pick an adventure and start learning by doing.</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {adventures.map((a) => <AdventureCard adventure={{ ...a, isLive: isLive(a) }} />)}
    </div>
  </main>
</Layout>
