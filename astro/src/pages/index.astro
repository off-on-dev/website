---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { BRAND_NAME, BRAND_SHORT_DESCRIPTION, COMMUNITY_URL } from "@/lib/site";
import { stripHtml } from "@/lib/markdown";

const MONTHS = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
const monthKey = (m: string): number => {
  const [mon, year] = m.split(" ");
  return Number(year) * 12 + Math.max(0, MONTHS.indexOf(mon));
};

const featured = (await getCollection("adventures"))
  .map((a) => a.data)
  .sort((x, y) => monthKey(y.month) - monthKey(x.month))
  .slice(0, 3);

const base = import.meta.env.BASE_URL;
---

<Layout title={`${BRAND_NAME} - Learn Open Source by Doing`} description={BRAND_SHORT_DESCRIPTION} path="/">
  <main id="main-content" tabindex="-1">
    <section class="mx-auto max-w-4xl px-4 py-20 text-center">
      <p class="text-sm uppercase tracking-widest text-faint">Vendor-Neutral · Open Source · Community-Driven</p>
      <h1 class="mt-4 text-4xl font-bold text-foreground md:text-5xl">
        <span class="block">always On.</span>
        <span class="block">always Open.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-dim">{BRAND_SHORT_DESCRIPTION}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a class="btn-primary" href={`${base}challenges/`}>Explore Challenges</a>
        <a class="btn-ghost" href={COMMUNITY_URL} target="_blank" rel="noopener noreferrer" aria-describedby="new-tab-hint">
          Join the Community
        </a>
      </div>
    </section>

    <section aria-labelledby="featured-heading" class="mx-auto max-w-5xl px-4 pb-20">
      <div class="flex items-baseline justify-between">
        <h2 id="featured-heading" class="text-2xl font-bold text-foreground">Latest Adventures</h2>
        <a class="docs-ext-link text-sm" href={`${base}adventures/`}>All adventures</a>
      </div>
      <ul class="mt-6 grid gap-4 sm:grid-cols-3">
        {featured.map((a) => (
          <li class="rounded-lg border border-border p-5">
            <a class="docs-ext-link text-lg font-semibold text-foreground" href={`${base}adventures/${a.slug}/`}>{a.title}</a>
            <p class="mt-1 text-xs uppercase tracking-widest text-faint">{a.month}</p>
            <p class="mt-2 text-sm text-dim line-clamp-3">{stripHtml(a.story)}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
